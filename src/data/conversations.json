      { "id": "m23", "from": "bot", "text": "Mercado Pago tiene promo de 3 cuotas sin interés todos los días. Para 6 hay que esperar promo de fin de mes.", "at": "2026-05-03T11:33:40.000Z" },
      { "id": "m24", "from": "client", "text": "Espero la promo entonces. ¿Cuándo es?", "at": "2026-05-03T11:36:00.000Z" },
      { "id": "m25", "from": "bot", "text": "Las promos de Mercado Pago suelen activarse el 28-30 de cada mes. Te puedo avisar cuando salga.", "at": "2026-05-03T11:36:30.000Z" },
      { "id": "m26", "from": "client", "text": "Dale, anotame", "at": "2026-05-03T11:38:00.000Z" },
      { "id": "m27", "from": "bot", "text": "Listo, quedaste anotado. ¿Querés que mientras tanto te reservemos la madera con seña de $50.000?", "at": "2026-05-03T11:38:50.000Z" },
