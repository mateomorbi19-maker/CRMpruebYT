      { "id": "m36", "from": "client", "text": "¿Cuánto sale el fitting?", "at": "2026-05-04T14:38:00.000Z" },
      { "id": "m37", "from": "bot", "text": "El fitting de madera son $25.000, pero si comprás se descuenta del total.", "at": "2026-05-04T14:38:40.000Z" },
