      { "id": "m31", "from": "bot", "text": "Jajaja sin problema Tomás. Quedo atento.", "at": "2026-05-03T11:42:30.000Z" },
      { "id": "m32", "from": "client", "text": "Buenas, ya la luz verde 🟢", "at": "2026-05-04T14:30:00.000Z" },
      { "id": "m33", "from": "bot", "text": "¡Excelente! ¿Avanzamos con la seña entonces?", "at": "2026-05-04T14:31:00.000Z" },
      { "id": "m34", "from": "client", "text": "Sí. Pero antes una última: ¿hacen prueba en cancha?", "at": "2026-05-04T14:35:00.000Z" },
